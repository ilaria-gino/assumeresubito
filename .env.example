# Copia questo file come `.env` e incolla la chiave anon dal progetto Supabase:
# Dashboard → Settings → API → Project URL + anon public key

VITE_SUPABASE_URL=https://suyrbiitbtfftdzjikig.supabase.co
VITE_SUPABASE_ANON_KEY=

# Opzionale: URL canonico (stesso host del redirect server / Search Console). Default: https://www.lavoro48h.it
# Usato in build per canonical, og:url, sitemap.xml e robots.txt in dist/.
# VITE_SITE_URL=https://lavoro48h.it

# Opzionale: se valorizzata, il sito mostra una schermata password (staging). Vedi docs/GO_LIVE_E_ROADMAP.md
# Non usare in build pubblica se la password deve restare segreta (finisce nel bundle Vite).
# VITE_STAGING_PASSWORD=
